<%- include("navbar",{title:"Toplu Bordro"}) %>
<main class="bulk-print-main">
    <div class="banner">Toplu Bordro - <%= month %></div>
    <button type="button" onclick="window.print()"><i class="fa-solid fa-print"></i>Yazdır / PDF</button>

    <% bordroList.forEach(bordro => { %>
        <section class="print-sheet payroll-sheet compact-sheet one-page-sheet">
            <div class="sheet-header">
                <div>
                    <h1><%= bordro.personel_name %></h1>
                    <p><%= bordro.payroll_month %> bordro hesaplama dökümü</p>
                </div>
                <img src="/logo.webp" alt="Sabırlar" class="sheet-logo">
            </div>

            <div class="compact-meta">
                <span>TCKN: <strong><%= bordro.tckn || "-" %></strong></span>
                <span>Görev: <strong><%= bordro.role || "-" %></strong></span>
                <span>Gün: <strong><%= bordro.working_days %></strong></span>
                <span>Mesai: <strong><%= bordro.overtime_days %> gün / <%= bordro.overtime_hours %> saat</strong></span>
            </div>

            <table class="payroll-table compact-table">
                <tbody>
                    <tr>
                        <th>Brüt</th>
                        <td><%= bordro.formattedCalculations.officialGrossSalary %> TL</td>
                        <th>Mesai</th>
                        <td><%= bordro.formattedCalculations.overtimeGross %> TL</td>
                    </tr>
                    <tr>
                        <th>Toplam Brüt</th>
                        <td><%= bordro.formattedCalculations.grossEarnings %> TL</td>
                        <th>SGK + İşsizlik</th>
                        <td><%= ((bordro.calculations.sgkEmployee + bordro.calculations.unemploymentEmployee).toFixed(2)) %> TL</td>
                    </tr>
                    <tr>
                        <th>GV Matrahı</th>
                        <td><%= bordro.formattedCalculations.incomeTaxBase %> TL</td>
                        <th>GV + Damga</th>
                        <td><%= ((bordro.calculations.incomeTax + bordro.calculations.stampTax).toFixed(2)) %> TL</td>
                    </tr>
                    <tr>
                        <th>Resmi Net</th>
                        <td><%= bordro.formattedCalculations.officialNetSalary %> TL</td>
                        <th>Maaş Üstü</th>
                        <td><%= bordro.formattedCalculations.salaryExtraAmount %> TL</td>
                    </tr>
                    <tr>
                        <th>Avans</th>
                        <td><%= bordro.formattedCalculations.advancePayment %> TL</td>
                        <th>İcra</th>
                        <td><%= bordro.formattedCalculations.icraDeduction %> TL</td>
                    </tr>
                    <tr class="compact-total-row">
                        <th>Ödenecek Net</th>
                        <td><strong><%= bordro.formattedCalculations.payoutAmount %> TL</strong></td>
                        <th>Durum</th>
                        <td><%= bordro.minimum_wage_paid ? "Resmi net ödendi" : "Resmi net bekliyor" %> / <%= bordro.salary_extra_sent ? "Maaş üstü gönderildi" : "Maaş üstü bekliyor" %></td>
                    </tr>
                </tbody>
            </table>

            <% if (bordro.notes) { %>
                <p class="notes compact-notes"><%= bordro.notes %></p>
            <% } %>
        </section>
    <% }) %>

    <% if (bordroList.length === 0) { %>
        <div class="empty-state">
            <i class="fa-solid fa-file-invoice-dollar"></i>
            <strong>Bu ay için bordro yok</strong>
            <span>Toplu çıktı almak için önce bordro kayıtları oluşturun.</span>
        </div>
    <% } %>
</main>
<% if (autoPrint) { %>
    <script>
        window.addEventListener("load", () => window.print())
    </script>
<% } %>
<%- include("footer") %>
